# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================

# Nombre de la aplicación (se muestra en la interfaz)
APP_NAME="Sistema de Contabilidad Médica"

# Entorno de ejecución: local, production, staging
APP_ENV=local

# Clave de encriptación de Laravel (generar con: php artisan key:generate)
APP_KEY=

# Modo debug: true para desarrollo, false para producción
APP_DEBUG=true

# URL base de la aplicación
APP_URL=http://localhost

# Idioma principal de la aplicación (español)
APP_LOCALE=es

# Idioma de respaldo si no está disponible el principal
APP_FALLBACK_LOCALE=en

# Idioma para datos faker en seeders
APP_FAKER_LOCALE=es_ES

# Driver para modo de mantenimiento
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Número de workers para el servidor CLI de PHP
# PHP_CLI_SERVER_WORKERS=4

# Rondas de encriptación para bcrypt (mayor = más seguro pero más lento)
BCRYPT_ROUNDS=12

# ============================================
# CONFIGURACIÓN DE LOGS
# ============================================

# Canal de logging: stack, single, daily, slack, syslog, errorlog
LOG_CHANNEL=stack

# Canales incluidos en el stack
LOG_STACK=single

# Canal para logs de deprecaciones
LOG_DEPRECATIONS_CHANNEL=null

# Nivel mínimo de log: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================

# Driver de base de datos: mysql, pgsql, sqlite, sqlsrv
DB_CONNECTION=mysql

# Host del servidor MySQL
DB_HOST=127.0.0.1

# Puerto del servidor MySQL (por defecto: 3306)
DB_PORT=3306

# Nombre de la base de datos
DB_DATABASE=contabilidad_medica

# Usuario de la base de datos
DB_USERNAME=root

# Contraseña del usuario de la base de datos
DB_PASSWORD=

# ============================================
# CONFIGURACIÓN DE SESIONES
# ============================================

# Driver de sesiones: file, cookie, database, apc, memcached, redis, dynamodb, array
SESSION_DRIVER=database

# Tiempo de vida de la sesión en minutos
SESSION_LIFETIME=120

# Encriptar datos de sesión
SESSION_ENCRYPT=false

# Ruta de la cookie de sesión
SESSION_PATH=/

# Dominio de la cookie de sesión (null = dominio actual)
SESSION_DOMAIN=null

# ============================================
# CONFIGURACIÓN DE BROADCASTING
# ============================================

# Driver de broadcasting: log, redis, pusher, ably, null
BROADCAST_CONNECTION=log

# ============================================
# CONFIGURACIÓN DE FILESYSTEM
# ============================================

# Disco de almacenamiento por defecto: local, public, s3
FILESYSTEM_DISK=local

# ============================================
# CONFIGURACIÓN DE COLAS
# ============================================

# Driver de colas: sync, database, beanstalkd, sqs, redis, null
QUEUE_CONNECTION=database

# ============================================
# CONFIGURACIÓN DE CACHÉ
# ============================================

# Driver de caché: apc, array, database, file, memcached, redis, dynamodb, octane
CACHE_STORE=database

# Prefijo para las claves de caché
# CACHE_PREFIX=

# ============================================
# CONFIGURACIÓN DE MEMCACHED
# ============================================

# Host del servidor Memcached
MEMCACHED_HOST=127.0.0.1

# ============================================
# CONFIGURACIÓN DE REDIS
# ============================================

# Cliente de Redis: phpredis, predis
REDIS_CLIENT=phpredis

# Host del servidor Redis
REDIS_HOST=127.0.0.1

# Contraseña de Redis (null si no tiene)
REDIS_PASSWORD=null

# Puerto del servidor Redis
REDIS_PORT=6379

# ============================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# ============================================

# Driver de correo: smtp, sendmail, mailgun, ses, postmark, log, array, failover, roundrobin
MAIL_MAILER=log

# Esquema de conexión: null, tls, ssl
MAIL_SCHEME=null

# Host del servidor SMTP
MAIL_HOST=127.0.0.1

# Puerto del servidor SMTP
MAIL_PORT=2525

# Usuario para autenticación SMTP
MAIL_USERNAME=null

# Contraseña para autenticación SMTP
MAIL_PASSWORD=null

# Dirección de correo del remitente
MAIL_FROM_ADDRESS="hello@example.com"

# Nombre del remitente
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# CONFIGURACIÓN DE AWS (OPCIONAL)
# ============================================

# Clave de acceso de AWS (para S3, SES, etc.)
AWS_ACCESS_KEY_ID=

# Clave secreta de AWS
AWS_SECRET_ACCESS_KEY=

# Región de AWS por defecto
AWS_DEFAULT_REGION=us-east-1

# Nombre del bucket de S3
AWS_BUCKET=

# Usar endpoint de estilo path para S3
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# CONFIGURACIÓN DE STRIPE (PAGOS SaaS)
# ============================================

# Clave publicable de Stripe
STRIPE_KEY=

# Clave secreta de Stripe
STRIPE_SECRET=

# Secreto del webhook de Stripe (para verificación de firmas)
STRIPE_WEBHOOK_SECRET=

# ============================================
# CONFIGURACIÓN DE VITE (FRONTEND)
# ============================================

# Nombre de la aplicación para Vite
VITE_APP_NAME="${APP_NAME}"

# ============================================
# CONFIGURACIÓN DE TELEGRAM BOT
# ============================================

# Token del bot de Telegram (proporcionado por @BotFather)
TELEGRAM_BOT_TOKEN=

# Nombre de usuario del bot
TELEGRAM_BOT_USERNAME=

# URL pública del webhook (ej: https://tudominio.com/telegram/webhook)
TELEGRAM_WEBHOOK_URL=

# Google Calendar OAuth 2.0 (obtained from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/google-calendar/callback
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo

